<!DOCTYPE html>
<html lang="id">
<head>
	<meta charset="UTF-8">
	<title>TABEL KONTROL</title>
	<link rel="stylesheet" href="style.css">
	<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>
	<section>
		<h1>Input</h1>
		<div>
			<input id="tanggal" type="date" placeholder="dd/mm/yy">
			<input id="kelas" type="text" placeholder="Contoh: XI IPA 11">
			<input id="mata_pelajaran" type="text" placeholder="mata pelajaran">
			<input id="keterangan" type="text" placeholder="keterangan">
			<button onclick="tambahData()">
				Tambah
			</button>
		</div>
	</section>
	<section>
		<h1>Tampilan</h1>
		<div id="hasil"></div>
		<script src="script.js"></script>
	</section>
</body>
</html>
